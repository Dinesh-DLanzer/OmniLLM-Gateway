# ============================================
# LiteLLM Proxy – Environment Variables
# ============================================
# Copy this file to .env and set the keys you own.

# Proxy authentication
LITELLM_MASTER_KEY=litellm-master-key # Change this to a secure password
UI_USERNAME=admin
UI_PASSWORD=litellm-master-key # Change this to a secure password

# ── Config Generator Tuning ──────────────────
# Minimum quality score (0-100) to include a model in config.yaml
# QUALITY_THRESHOLD=30
# Skip retesting models already tested in the last N hours (0 = always retest)
# CACHE_HOURS=24

# ── Providers ───────────────────────────────

# BOA API (Claude, GPT-5, Gemini, Grok)
# BOA_API_KEY=your_boa_key

# OpenRouter (free + paid)
# OPENROUTER_API_KEY=your_openrouter_key

# NVIDIA NIM (free tier works with this key)
# NVIDIA_API_KEY=your_nvidia_key

# AWS Bedrock (required for Sonnet 4.5)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# clod.io (free models)
# CLOD_API_KEY=your_clod_jwt

# Groq (very fast, generous free tier)
# GROQ_API_KEY=gsk_...

# Cerebras (fast, free tier)
# CEREBRAS_API_KEY=csk_...

# Cohere (1000 calls/month free)
# COHERE_API_KEY=...

# Mistral AI (free tier)
# MISTRAL_API_KEY=...

# Together AI (large open-source catalog)
# TOGETHER_API_KEY=...

# Fireworks AI (very fast inference)
# FIREWORKS_API_KEY=...

# DeepSeek (R1 reasoning model)
# DEEPSEEK_API_KEY=...

# xAI / Grok-3
# XAI_API_KEY=...

# Perplexity (Sonar online models)
# PERPLEXITY_API_KEY=...

# Langfuse (optional – for observability)
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Database & Cache
# IMPORTANT: If you change DB_PASSWORD, you must also update the password in DATABASE_URL
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm
DB_PASSWORD=litellm